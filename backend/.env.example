# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=AI Inventory Management System
VERSION=1.0.0
DESCRIPTION=Production-ready inventory management system with AI forecasting

# CORS Settings (comma-separated origins)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security Settings
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Settings
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory_db
POSTGRES_PORT=5432
# Or use DATABASE_URI directly:
# DATABASE_URI=postgresql+asyncpg://user:password@localhost:5432/inventory_db

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Email Settings (optional)
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@inventory.com
EMAILS_FROM_NAME=Inventory System

# Super Admin
FIRST_SUPERUSER_EMAIL=admin@inventory.com
FIRST_SUPERUSER_PASSWORD=admin123

# Environment
ENVIRONMENT=development
DEBUG=True

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# File Upload
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=uploads

# AI/ML Settings
AI_MODEL_PATH=models/
FORECAST_DAYS=30
