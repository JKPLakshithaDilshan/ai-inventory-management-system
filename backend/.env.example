# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=AI Inventory Management System
VERSION=1.0.0
DESCRIPTION=Production-ready inventory management system with AI forecasting

# CORS Settings
# Optional explicit override (all environments). Leave empty to use *_DEV or *_PROD list.
BACKEND_CORS_ORIGINS=[]
# Development origins only (keep localhost here only).
BACKEND_CORS_ORIGINS_DEV=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]
# Production origins must be explicit domains (no wildcard, no localhost).
BACKEND_CORS_ORIGINS_PROD=["https://app.example.com","https://admin.example.com"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization","Content-Type","Accept","Origin","X-Requested-With"]
CORS_EXPOSE_HEADERS=["Content-Disposition"]

# Security Settings
SECRET_KEY=change-this-to-a-long-random-string-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Optional JWT claim validation (recommended in production)
JWT_ISSUER=
JWT_AUDIENCE=

# Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_DB=ai_inventory_db
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
# Or use DATABASE_URI directly:
# DATABASE_URI=postgresql+asyncpg://user:password@localhost:5432/inventory_db

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Email Settings (optional)
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@inventory.com
EMAILS_FROM_NAME=Inventory System

# Super Admin
FIRST_SUPERUSER_EMAIL=admin@inventory.com
FIRST_SUPERUSER_PASSWORD=change-this-password

# Environment
ENVIRONMENT=development
DEBUG=True

# Host/Proxy Hardening
# In production, set this to your real hostnames and remove localhost values.
TRUSTED_HOSTS=["localhost","127.0.0.1"]
ENABLE_PROXY_HEADERS=False
FORWARDED_ALLOW_IPS=127.0.0.1

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_DEFAULT_REQUESTS=60
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_LOGIN_REQUESTS=20
RATE_LIMIT_AUTH_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REFRESH_REQUESTS=10
RATE_LIMIT_AUTH_REFRESH_WINDOW_SECONDS=60
RATE_LIMIT_AI_REQUESTS=20
RATE_LIMIT_AI_WINDOW_SECONDS=60
RATE_LIMIT_ALERTS_REQUESTS=20
RATE_LIMIT_ALERTS_WINDOW_SECONDS=60
# Deprecated alias, kept for backward compatibility:
# RATE_LIMIT_PER_MINUTE=60

# File Upload
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=uploads

# AI/ML Settings
AI_MODEL_PATH=models/
FORECAST_DAYS=30
